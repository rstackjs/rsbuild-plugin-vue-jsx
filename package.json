{
  "name": "@rsbuild/plugin-vue-jsx",
  "version": "2.0.1",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-vue-jsx",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-vue-jsx#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-vue-jsx/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "npx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "@rsbuild/plugin-babel": "^2.0.1",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "babel-plugin-vue-jsx-hmr": "^1.0.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.2",
    "@rsbuild/plugin-vue": "2.0.1",
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.4",
    "@rstackjs/test-utils": "^0.2.0",
    "@rstest/core": "^0.11.1",
    "@rstest/playwright": "^0.11.1",
    "@types/node": "^24.13.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2",
    "vue": "^3.5.39"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
